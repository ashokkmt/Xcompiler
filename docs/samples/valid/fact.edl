let num: int = 5;
let factorial: int = 1;

if num < 0 {
    print("Factorial does not exist for negative numbers.");
} else {
    if (num == 0) {
        print("The factorial of 0 is 1.");
    } else {
        let i: int = 1;
        while (i <= num) {
            factorial = factorial * i;
            i = i + 1;
        }
        print("The factorial is:");
        print(factorial);
    }
}

